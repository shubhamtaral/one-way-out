rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if user is the owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // User profiles and stats
    match /users/{userId} {
      allow read: if true; // Public profiles for leaderboards
      allow write: if isOwner(userId) && 
        request.resource.data.displayName is string && 
        request.resource.data.displayName.size() <= 100;
    }

    // Leaderboard scores
    match /leaderboard/{scoreId} {
      allow read: if true;
      // Ensure user can only write their own score and it's valid data
      allow create, update: if isAuthenticated() && 
        request.auth.uid == request.resource.data.userId &&
        request.resource.data.displayName is string &&
        request.resource.data.displayName.size() <= 100 &&
        request.resource.data.level is number &&
        request.resource.data.level >= 0 &&
        request.resource.data.level <= 500 && // Safety cap (can be adjusted)
        request.resource.data.wpm is number &&
        request.resource.data.wpm >= 0 &&
        request.resource.data.wpm <= 350 && // Human-realistic WPM cap
        request.resource.data.difficulty in ['casual', 'normal', 'nightmare'];
      allow delete: if false;
    }

    // Daily challenge scores
    match /daily/{dailyScoreId} {
      allow read: if true;
      allow create, update: if isAuthenticated() && 
        request.auth.uid == request.resource.data.userId &&
        request.resource.data.displayName is string &&
        request.resource.data.displayName.size() <= 100 &&
        request.resource.data.level is number &&
        request.resource.data.level >= 0 &&
        request.resource.data.level <= 500;
      allow delete: if false;
    }

    // Connection test document
    match /test/connection_test {
      allow read, write: if true; // This is just for testing connectivity
    }
  }
}
